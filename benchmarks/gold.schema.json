{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLM Graph Gold Example",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "benchmark_version",
    "split",
    "coverage_topic",
    "subject",
    "relation",
    "object",
    "evidence",
    "labels",
    "review"
  ],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "benchmark_version": {"type": "integer", "minimum": 1},
    "split": {"enum": ["train", "validation", "test"]},
    "coverage_topic": {"type": "string", "minLength": 1},
    "subject": {"$ref": "#/$defs/entity"},
    "relation": {"type": "string", "minLength": 1},
    "object": {"$ref": "#/$defs/entity"},
    "qualifiers": {"type": "object"},
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/evidence"}
    },
    "labels": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subject_resolution",
        "object_resolution",
        "relation_valid",
        "direction_valid",
        "claim_valid"
      ],
      "properties": {
        "subject_resolution": {"enum": ["same_entity", "different_entity", "facet_of", "ambiguous"]},
        "object_resolution": {"enum": ["same_entity", "different_entity", "facet_of", "ambiguous"]},
        "relation_valid": {"type": "boolean"},
        "correct_relation": {"type": ["string", "null"]},
        "direction_valid": {"type": "boolean"},
        "claim_valid": {"enum": ["approve", "reject", "needs_more_evidence"]}
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewer", "rationale", "reviewed_at"],
      "properties": {
        "reviewer": {"type": "string", "minLength": 1},
        "rationale": {"type": "string", "minLength": 1},
        "reviewed_at": {"type": "string", "format": "date-time"}
      }
    }
  },
  "$defs": {
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "entity_type"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "entity_type": {"type": "string", "minLength": 1},
        "canonical_id": {"type": ["string", "null"]}
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_snapshot",
        "source_family",
        "excerpt",
        "location",
        "polarity",
        "entailment"
      ],
      "properties": {
        "source_snapshot": {"type": "string", "minLength": 1},
        "source_family": {"type": "string", "minLength": 1},
        "excerpt": {"type": "string", "minLength": 1},
        "location": {"type": "string", "minLength": 1},
        "polarity": {"enum": ["support", "oppose", "uncertain"]},
        "entailment": {"enum": ["supports", "contradicts", "insufficient"]},
        "mechanically_valid": {"type": "boolean"}
      }
    }
  }
}
